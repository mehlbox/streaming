# ── Main server settings ──────────────────────────────────────────────
# Docker Compose profile: "main" for origin server, "satellite" for edge nodes
COMPOSE_PROFILES=main
SECRET_KEY=replace-this-with-a-random-32-plus-character-secret
# STREAM_KEY=your-rtmp-key
# THEME=ocean
# SITE_TITLE=My Live Stream
# SITE_SUBTITLE=Live aus dem Studio.
# STREAMING_HOST=streaming.example.com
# Recommended when the main app sits behind Traefik or another TLS proxy.
# Satellites will use this HTTPS origin as their upstream pull source.
# SATELLITE_BOOTSTRAP_ORIGIN_URL=https://streaming.example.com
# Optional: share the viewer cookie across subdomains so satellites can read it
# HLS_VIEWER_COOKIE_DOMAIN=example.com

# ── Satellite system ─────────────────────────────────────────────────
# Shared secret between main server and all satellites (required)
SATELLITE_API_KEY=change-me-to-a-random-secret
# Separate token used to download the bootstrap installer script.
# If unset, the installer endpoint falls back to SATELLITE_API_KEY.
# SATELLITE_BOOTSTRAP_TOKEN=change-me-too
# Bootstrap identities are always auto-assigned as `node1`, `node2`, ...
# The public URL is generated from this template. Defaults to
# `https://{name}.example.com/hls` when HLS_VIEWER_COOKIE_DOMAIN is set,
# otherwise tries to derive the zone from STREAMING_HOST.
# SATELLITE_BOOTSTRAP_NAME_PREFIX=node
# SATELLITE_BOOTSTRAP_PUBLIC_URL_TEMPLATE=https://{name}.example.com/hls
# Path for the persisted IP/name/DNS map used by auto-assignment and
# server-status DNS verification.
# SATELLITE_NODE_MAP_PATH=/app/satellite-nodes.json
# Optional: manage up to 5 new satellite VMs from the `/debug` page via
# the Scaleway Instances API. This integration uses `SCW_SECRET_KEY`
# against `https://api.scaleway.com`; `SCW_ACCESS_KEY` is kept only for
# parity with Scaleway's usual env naming. `SCW_MANAGE_TOKEN` is now a
# server-side enable flag and is not prompted in the UI.
# SCW_MANAGE_TOKEN=choose-a-separate-debug-token
# SCW_SECRET_KEY=your-scaleway-secret-key
# SCW_ACCESS_KEY=your-scaleway-access-key
# SCW_DEFAULT_PROJECT_ID=your-scaleway-project-id
# SCW_DEFAULT_ORGANIZATION_ID=your-scaleway-organization-id
# SCW_DEFAULT_ZONE=fr-par-1
# SCW_DEFAULT_COMMERCIAL_TYPE=GP1-S
# SCW_DEFAULT_IMAGE=ubuntu_noble
# SCW_ROOT_VOLUME_TYPE=l_ssd
# SCW_ROOT_VOLUME_SIZE_GB=10
# SCW_SERVER_NAME_PREFIX=instance
# SCW_SERVER_LIMIT=5

# ── Satellite-only settings (used when running with --profile satellite)
# Public URL where viewers will fetch HLS from this satellite
SATELLITE_PUBLIC_URL=https://node1.example.com/hls
# Optional ACME contact for the satellite's own HTTPS certificates
# CADDY_EMAIL=streaming@example.com
# Human-readable name for this satellite
SATELLITE_NAME=node1
# Max viewer capacity for this satellite. When bootstrap installs a node
# directly on a VM, this acts as the fallback if the speedtest-based
# calculation fails. If you set it explicitly before running the installer,
# that manual value wins over auto-calculation.
SATELLITE_MAX_VIEWERS=200
# Assumed upstream bandwidth per viewer for bootstrap-time capacity sizing.
# The installer runs 3 upload speed tests, averages them, subtracts 20%, and
# divides the result by this value to derive SATELLITE_MAX_VIEWERS.
# SATELLITE_VIEWER_MBPS=3.5
# SATELLITE_SPEEDTEST_RUNS=3
# SATELLITE_SPEEDTEST_MARGIN_PERCENT=20
# Main server URL the satellite agent connects to
MAIN_SERVER_URL=https://streaming.example.com
# Internal URL the satellite nginx uses to pull HLS segments from main
MAIN_SERVER_INTERNAL_URL=http://host.docker.internal
# Internal loopback port used by the satellite's local nginx origin
SATELLITE_PORT=8080
